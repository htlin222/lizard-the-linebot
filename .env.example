# Copy this file to `.env` (gitignored) and fill in the values.
#
#   cp .env.example .env
#
# Recommended order:
#   1. Fill in the LINE values from the LINE Developers Console.
#   2. Create the Turso DB and fill in TURSO_DATABASE_URL + TURSO_AUTH_TOKEN.
#   3. Push all four into Cloudflare via `wrangler secret put`.
#   4. Mirror them into `.dev.vars` so `pnpm dev` works locally.

# ---- LINE -------------------------------------------------------------------
# developers.line.biz  →  your channel  →  Basic settings  →  "Channel secret"
LINE_CHANNEL_SECRET=

# developers.line.biz  →  your channel  →  Messaging API  →
#   "Channel access token (long-lived)"  →  click Issue, then copy
LINE_CHANNEL_ACCESS_TOKEN=

# ---- Turso ------------------------------------------------------------------
# Create the DB first:  turso db create lizard
# Then:                 turso db show lizard --url
# Token:                turso db tokens create lizard
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
