# Copy this file to `.env` (gitignored) and fill in the values.
#
#   cp .env.example .env
#
# After you paste the LINE values, tell me and I'll:
#   1. create the Turso DB and append TURSO_DATABASE_URL + TURSO_AUTH_TOKEN here
#   2. push all four into Cloudflare via `wrangler secret put`
#   3. mirror them into .dev.vars so `pnpm dev` works locally

# ---- LINE (you fill these in now) -------------------------------------------
# developers.line.biz  →  your channel  →  Basic settings  →  "Channel secret"
LINE_CHANNEL_SECRET=

# developers.line.biz  →  your channel  →  Messaging API  →
#   "Channel access token (long-lived)"  →  click Issue, then copy
LINE_CHANNEL_ACCESS_TOKEN=

# ---- Turso (I'll fill these in for you after `turso db create lizard`) ------
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
